<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2>Browse Projects by Category</h2>
    <ul>
        <% categories.forEach((category) => { %>
            <a href="/category/<%= category.category_id %>"><%= category.name %></a>
        <% }) %>
    </ul>
</main>
<%- include('partials/footer') %>